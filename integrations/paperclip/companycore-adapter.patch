+import { describe, expect, it } from "vitest";
+import {
+  buildIssueFromCompanyCoreEvent,
+  loadCompanyCoreAdapterConfig,
+} from "../services/companycore-adapter.js";
+
+describe("CompanyCore adapter", () => {
+  it("stays disabled without the CompanyCore base URL and API key", () => {
+    expect(loadCompanyCoreAdapterConfig({})).toBeNull();
+    expect(loadCompanyCoreAdapterConfig({ COMPANYCORE_BASE_URL: "https://api.example.test" })).toBeNull();
+    expect(loadCompanyCoreAdapterConfig({ COMPANYCORE_API_KEY: "secret" })).toBeNull();
+  });
+
+  it("loads safe polling defaults from environment variables", () => {
+    const config = loadCompanyCoreAdapterConfig({
+      COMPANYCORE_BASE_URL: "https://api.example.test/",
+      COMPANYCORE_API_KEY: "secret",
+    });
+
+    expect(config).toMatchObject({
+      baseUrl: "https://api.example.test",
+      targetAgent: "paperclip",
+      source: "paperclip",
+      intervalMs: 30_000,
+      batchLimit: 25,
+    });
+  });
+
+  it("builds an idempotent Paperclip issue from a CompanyCore event", () => {
+    const issue = buildIssueFromCompanyCoreEvent(
+      {
+        id: "agent-event-1",
+        eventId: "event-1",
+        eventType: "task_status_updated_from_clickup",
+        scope: {
+          taskId: "task-1",
+          externalId: "clickup-1",
+        },
+        payload: {
+          before: { status: "todo" },
+          after: { status: "done" },
+          provider: "clickup",
+        },
+        createdAt: "2026-05-03T10:00:00.000Z",
+      },
+      "paperclip",
+    );
+
+    expect(issue).toMatchObject({
+      title: "CompanyCore task status updated from clickup (clickup-1)",
+      status: "todo",
+      priority: "medium",
+      originKind: "companycore_agent_event",
+      originId: "agent-event-1",
+      originFingerprint: "event-1",
+    });
+    expect(issue.description).toContain("Status: todo -> done");
+    expect(issue.description).toContain('"provider": "clickup"');
+  });
+});
